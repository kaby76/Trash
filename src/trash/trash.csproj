<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<PackAsTool>true</PackAsTool>
		<GeneratePackageOnBuild>false</GeneratePackageOnBuild>
		<PackageReadmeFile>readme.md</PackageReadmeFile>
		<PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
		<AssemblyName>trash</AssemblyName>
		<PackageId>trash</PackageId>
		<ToolCommandName>trash</ToolCommandName>
		<Description>
			<![CDATA[The Trash toolkit dispatcher. Provides trgen, trparse, trtree, and all other
Trash parse-tree manipulation tools under a single install.
Usage: trash <command> [options]  (e.g. trash trgen, trash gen, trash trparse)]]>
		</Description>
		<RootNamespace>Trash</RootNamespace>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<DebugType>portable</DebugType>
		<DebugSymbols>true</DebugSymbols>
		<Version>1.1.0</Version>
		<RepositoryUrl>https://github.com/kaby76/Trash/tree/main/src/trash</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
	</PropertyGroup>

	<!-- Sub-tool DLLs pre-published into staging/ by _scripts/pack-trash.sh -->
	<ItemGroup>
		<None Include="staging\**\*" Pack="true" PackagePath="tools/net10.0/any/" />
	</ItemGroup>

	<ItemGroup>
		<None Include="readme.md" Pack="true" PackagePath="" />
		<EmbeddedResource Include="readme.md" />
	</ItemGroup>

	<PropertyGroup>
		<RestoreProjectStyle>PackageReference</RestoreProjectStyle>
		<PackageReleaseNotes>(Edit readme.md.)</PackageReleaseNotes>
	</PropertyGroup>

	<Target Name="PreparePackageReleaseNotesFromFile" BeforeTargets="GenerateNuspec">
		<ReadLinesFromFile File="readme.md">
			<Output TaskParameter="Lines" ItemName="ReleaseNoteLines" />
		</ReadLinesFromFile>
		<PropertyGroup>
			<PackageReleaseNotes>@(ReleaseNoteLines, '%0a')</PackageReleaseNotes>
		</PropertyGroup>
	</Target>

</Project>
